# Application
APP_NAME=SafeQuery AI
APP_ENV=development
DEBUG=true

# PostgreSQL container
POSTGRES_DB=safequery_db
POSTGRES_USER=safequery_admin
POSTGRES_PASSWORD=replace_with_a_local_password
POSTGRES_PORT=5432

# Backend database connection
DATABASE_URL=postgresql+psycopg://safequery_admin:replace_with_a_local_password@localhost:5432/safequery_db

# LLM provider - not used in Milestone 2
GROQ_API_KEY=replace_with_your_api_key

# Future query safety settings
MAX_RESULT_ROWS=1000
QUERY_TIMEOUT_SECONDS=10
MIN_CONFIDENCE_SCORE=0.65