# Application
APP_NAME=SafeQuery AI
APP_ENV=development
DEBUG=true

# PostgreSQL container
POSTGRES_DB=safequery_db
POSTGRES_USER=safequery_admin
POSTGRES_PASSWORD=replace_with_a_local_password
POSTGRES_PORT=5433

# Backend database connection
DATABASE_URL=postgresql+psycopg://safequery_admin:replace_with_a_local_password@127.0.0.1:5433/safequery_db
DATABASE_SCHEMA=public

# Schema introspection
SCHEMA_SAMPLE_LIMIT=5
SCHEMA_CATEGORICAL_MAX_DISTINCT=25

# Groq LLM
GROQ_API_KEY=replace_with_your_api_key
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0
GROQ_MAX_COMPLETION_TOKENS=1200
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2

# Query safety
MAX_RESULT_ROWS=1000
QUERY_TIMEOUT_SECONDS=10
MIN_CONFIDENCE_SCORE=0.65

# Static SQL guardrails
MAX_SQL_LENGTH=20000
MAX_SUBQUERY_DEPTH=3
BLOCK_SQL_COMMENTS=true
BLOCKED_SQL_FUNCTIONS=pg_sleep,pg_read_file,pg_read_binary_file,pg_ls_dir,lo_import,lo_export,dblink,dblink_exec
GUARDRAIL_LOG_FILE=logs/guardrails.log