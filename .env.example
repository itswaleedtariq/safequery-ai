# Application
APP_NAME=SafeQuery AI
APP_ENV=development
DEBUG=true

# PostgreSQL container
POSTGRES_DB=safequery_db
POSTGRES_USER=safequery_admin
POSTGRES_PASSWORD=replace_with_a_local_password
POSTGRES_PORT=5433

# Backend database connection
DATABASE_URL=postgresql+psycopg://safequery_admin:replace_with_a_local_password@127.0.0.1:5433/safequery_db
DATABASE_SCHEMA=public

# Schema introspection
SCHEMA_SAMPLE_LIMIT=5
SCHEMA_CATEGORICAL_MAX_DISTINCT=25

# LLM provider - used in a later milestone
GROQ_API_KEY=replace_with_your_api_key

# Query safety settings
MAX_RESULT_ROWS=1000
QUERY_TIMEOUT_SECONDS=10
MIN_CONFIDENCE_SCORE=0.65